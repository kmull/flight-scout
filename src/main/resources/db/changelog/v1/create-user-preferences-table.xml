<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="user_preferences-v1.0" author="kmuller">
        <createTable tableName="user_preferences">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_preferences_user"
                             references="users(id)"/>
            </column>

            <column name="home_airport" type="VARCHAR(3)"/>
            <column name="preferred_cabin" type="VARCHAR(20)"/>
            <column name="currency" type="VARCHAR(2)"/>
            <column name="email_alerts_enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <createIndex tableName="user_preferences" indexName="idx_user_preferences_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>