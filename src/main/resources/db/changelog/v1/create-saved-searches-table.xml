<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="saved_searches-v1.0" author="kmuller">
        <createTable tableName="saved_searches">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_saved_searches_user"/>
            </column>
            <column name="origin" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="destination" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="departure_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="return_date" type="DATE"/>
            <column name="passengers" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="cabin_class" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="saved_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="saved_searches" indexName="idx_saved_searches_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>